<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bibliotheque_municipale.controleur.AdherentsController">

    <top>
        <HBox style="-fx-background-color: #2E7D32; -fx-padding: 12 20;">
            <Label text="📚 Bibliotheque Municipale de Dakar"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #1B5E20; -fx-padding: 20 0; -fx-spacing: 5;" prefWidth="200.0">
            <Label text="NAVIGATION" style="-fx-text-fill: #81C784; -fx-font-size: 11px; -fx-padding: 10 15 5 15; -fx-font-weight: bold;"/>
            <Button text="🏠  Dashboard" prefWidth="200.0" prefHeight="40.0" onAction="#retourDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #C8E6C9; -fx-alignment: center-left; -fx-padding: 0 0 0 15; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="👥  Adherants" prefWidth="200.0" prefHeight="40.0"
                    style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 0 0 0 15; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #F1F8E9; -fx-padding: 20; -fx-spacing: 15;">
            <Label text="Gestion des Adherants" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>

            <HBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox HBox.hgrow="ALWAYS" spacing="12">
                    <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                        <TableView fx:id="tblAdherents" prefHeight="280.0">
                            <columns>
                                <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="120"/>
                                <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
                                <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="130"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="160"/>
                                <TableColumn fx:id="colTelephone" text="Telephone" prefWidth="110"/>
                                <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                        <Label text="Historique emprunts" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2E7D32; -fx-padding: 0 0 8 0;"/>
                        <TableView fx:id="tblHistorique" prefHeight="180.0">
                            <columns>
                                <TableColumn fx:id="colLivreHisto" text="Livre" prefWidth="280"/>
                                <TableColumn fx:id="colDateEmpHisto" text="Date emprunt" prefWidth="150"/>
                                <TableColumn fx:id="colStatutHisto" text="Statut" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-spacing: 10; -fx-background-radius: 8;" prefWidth="280.0">
                    <Label text="Infos adherant" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>

                    <Label text="Nom *"/>
                    <TextField fx:id="txtNom" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Prenom *"/>
                    <TextField fx:id="txtPrenom" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Email"/>
                    <TextField fx:id="txtEmail" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Telephone"/>
                    <TextField fx:id="txtTelephone" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Adresse"/>
                    <TextField fx:id="txtAdresse" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                    <Button text="Inscrire" onAction="#inscrire" prefHeight="36.0" prefWidth="240.0"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Modifier" onAction="#modifier" prefHeight="36.0" prefWidth="240.0"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Suspendre / Reactiver" onAction="#suspendre" prefHeight="36.0" prefWidth="240.0"
                            style="-fx-background-color: #F57F17; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Vider" onAction="#vider" prefHeight="36.0" prefWidth="240.0"
                            style="-fx-background-color: #757575; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
