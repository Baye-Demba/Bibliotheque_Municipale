<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="600.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bibliotheque_municipale.controleur.UtilisateursController">

    <top>
        <HBox style="-fx-background-color: #2E7D32; -fx-padding: 12 20;">
            <Label text="📚 Bibliotheque Municipale de Dakar"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #1B5E20; -fx-padding: 20 0; -fx-spacing: 5;" prefWidth="200.0">
            <Label text="NAVIGATION" style="-fx-text-fill: #81C784; -fx-font-size: 11px; -fx-padding: 10 15 5 15; -fx-font-weight: bold;"/>
            <Button text="🏠  Dashboard" prefWidth="200.0" prefHeight="40.0" onAction="#retourDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #C8E6C9; -fx-alignment: center-left; -fx-padding: 0 0 0 15; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
            <Button text="⚙  Utilisateurs" prefWidth="200.0" prefHeight="40.0"
                    style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 0 0 0 15; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #F1F8E9; -fx-padding: 20; -fx-spacing: 15;">
            <Label text="Gestion des Utilisateurs" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Label text="Admin seulement" style="-fx-font-size: 12px; -fx-text-fill: #C62828;"/>

            <HBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <TableView fx:id="tblUtilisateurs" VBox.vgrow="ALWAYS" prefHeight="500.0">
                        <columns>
                            <TableColumn fx:id="colLogin" text="Login" prefWidth="110"/>
                            <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                            <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="120"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                            <TableColumn fx:id="colProfil" text="Profil" prefWidth="120"/>
                            <TableColumn fx:id="colActif" text="Statut" prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-spacing: 10; -fx-background-radius: 8;" prefWidth="270.0">
                    <Label text="Infos utilisateur" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>

                    <Label text="Login *"/>
                    <TextField fx:id="txtLogin" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Nom"/>
                    <TextField fx:id="txtNom" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Prenom"/>
                    <TextField fx:id="txtPrenom" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Email"/>
                    <TextField fx:id="txtEmail" style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Profil"/>
                    <ComboBox fx:id="cboProfil" prefWidth="230.0" prefHeight="34.0"
                              style="-fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    <Label text="Mot de passe (creation seulement)"/>
                    <PasswordField fx:id="txtMotDePasse"
                                   style="-fx-pref-height: 34; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-background-radius: 4;"/>

                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                    <Button text="Creer" onAction="#ajouter" prefHeight="34.0" prefWidth="230.0"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Modifier" onAction="#modifier" prefHeight="34.0" prefWidth="230.0"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Activer / Desactiver" onAction="#changerStatut" prefHeight="34.0" prefWidth="230.0"
                            style="-fx-background-color: #F57F17; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Reinitialiser MDP" onAction="#reinitialiserMdp" prefHeight="34.0" prefWidth="230.0"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Vider" onAction="#vider" prefHeight="34.0" prefWidth="230.0"
                            style="-fx-background-color: #757575; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
            <Label text="© 2025 - ByDemba et Meissa"
                   style="-fx-font-size: 10px; -fx-text-fill: #bbb; -fx-padding: 30 0 0 0;"/>
        </VBox>
    </center>
</BorderPane>
